# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# JWT
JWT_SECRET=change-this-to-a-long-random-string
JWT_EXPIRE_HOURS=24

# Database
DATABASE_URL=postgresql://trademeter:password@localhost:5432/trademeter

# Redis
REDIS_URL=redis://localhost:6379

# ML
MLFLOW_TRACKING_URI=http://localhost:5001
MODEL_SNAPSHOT_INTERVAL=100
DRIFT_ACCURACY_THRESHOLD=0.60

# TCP listener (NinjaTrader connection)
NT_TCP_PORT=5000

# Environment
ENV=development
